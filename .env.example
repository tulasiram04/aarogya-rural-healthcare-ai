# AAROGYA Rural Health Platform - Environment Configuration Template
# Copy this file to '.env' and populate with actual credentials before startup.

# ==========================================
# 1. FastAPI Security & Session Settings
# ==========================================
# Secret key used for cryptographic JWT signing. Generate using: openssl rand -hex 32
SECRET_KEY=AAROGYA_SUPER_SECRET_TOKEN_SIGNING_KEY_256_BITS
# Expiration threshold for JWT access tokens (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==========================================
# 2. Database Settings (PostgreSQL)
# ==========================================
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aarogya
POSTGRES_PORT=5432

# In local host development (non-dockerized), uncomment the line below:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aarogya

# ==========================================
# 3. Cache & Message Brokers (Redis)
# ==========================================
REDIS_URL=redis://redis:6379/0

# In local host development (non-dockerized), uncomment the line below:
# REDIS_URL=redis://localhost:6379/0

# ==========================================
# 4. Third-Party API Services
# ==========================================
# Obtain from Telegram's @BotFather client
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Obtain from Google AI Studio (generativeai.google)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ==========================================
# 5. Object Storage Settings (AWS S3 / MinIO)
# ==========================================
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=aarogya-media

# ==========================================
# 6. Next.js Frontend Configuration
# ==========================================
# REST API Gateway Endpoint URL for Frontend Client Fetching
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
